{% assign bid = block.id | replace: '_', '' | downcase %}

{% style %}
  .kyn-compare-{{ bid }} {
    width: 100%;
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
  }

  .kyn-compare-{{ bid }} table {
    width: 100%;
    border-collapse: collapse;
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.4;
  }

  .kyn-compare-{{ bid }} thead th {
    padding: 12px 14px;
    text-align: left;
    font-weight: 700;
    font-size: {{ block.settings.font_size | plus: 1 }}px;
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .kyn-compare-{{ bid }} thead th:first-child {
    color: transparent;
    width: 30%;
  }

  .kyn-compare-{{ bid }} thead th.kyn-col-kyn {
    color: {{ block.settings.kyn_header_color }};
    background: {{ block.settings.kyn_header_bg }};
    border-radius: {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px 0 0;
    text-align: center;
    width: 35%;
  }

  .kyn-compare-{{ bid }} thead th.kyn-col-generic {
    color: {{ block.settings.generic_header_color }};
    text-align: center;
    width: 35%;
  }

  .kyn-compare-{{ bid }} tbody td {
    padding: 11px 14px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    vertical-align: middle;
  }

  .kyn-compare-{{ bid }} tbody td:first-child {
    font-weight: 600;
    color: {{ block.settings.label_color }};
  }

  .kyn-compare-{{ bid }} tbody td.kyn-col-kyn {
    text-align: center;
    color: {{ block.settings.kyn_text_color }};
    background: {{ block.settings.kyn_col_bg }};
    font-weight: 600;
  }

  .kyn-compare-{{ bid }} tbody td.kyn-col-generic {
    text-align: center;
    color: {{ block.settings.generic_text_color }};
  }

  .kyn-compare-{{ bid }} tbody tr:last-child td {
    border-bottom: none;
  }

  .kyn-compare-{{ bid }} tbody tr:last-child td.kyn-col-kyn {
    border-radius: 0 0 {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px;
  }

  .kyn-compare-{{ bid }} .kyn-cost-highlight {
    font-weight: 700;
    font-size: {{ block.settings.font_size | plus: 2 }}px;
    color: {{ block.settings.kyn_header_bg }};
  }

  .kyn-compare-{{ bid }} .kyn-cost-generic {
    text-decoration: line-through;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .kyn-compare-{{ bid }} table {
      font-size: {{ block.settings.font_size | minus: 1 }}px;
    }
    .kyn-compare-{{ bid }} thead th,
    .kyn-compare-{{ bid }} tbody td {
      padding: 9px 10px;
    }
  }
{% endstyle %}

<div class="kyn-compare-{{ bid }}" {{ block.shopify_attributes }}>
  <table role="table" aria-label="{{ block.settings.table_label }}">
    <thead>
      <tr>
        <th scope="col"></th>
        <th scope="col" class="kyn-col-kyn">{{ block.settings.col_kyn_header }}</th>
        <th scope="col" class="kyn-col-generic">{{ block.settings.col_generic_header }}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{ block.settings.row_1_label }}</td>
        <td class="kyn-col-kyn">{{ block.settings.row_1_kyn }}</td>
        <td class="kyn-col-generic">{{ block.settings.row_1_generic }}</td>
      </tr>
      <tr>
        <td>{{ block.settings.row_2_label }}</td>
        <td class="kyn-col-kyn">{{ block.settings.row_2_kyn }}</td>
        <td class="kyn-col-generic">{{ block.settings.row_2_generic }}</td>
      </tr>
      <tr>
        <td>{{ block.settings.row_3_label }}</td>
        <td class="kyn-col-kyn">{{ block.settings.row_3_kyn }}</td>
        <td class="kyn-col-generic">{{ block.settings.row_3_generic }}</td>
      </tr>
      <tr>
        <td>{{ block.settings.row_4_label }}</td>
        <td class="kyn-col-kyn"><span class="kyn-cost-highlight">{{ block.settings.row_4_kyn }}</span></td>
        <td class="kyn-col-generic"><span class="kyn-cost-generic">{{ block.settings.row_4_generic }}</span></td>
      </tr>
    </tbody>
  </table>
</div>

