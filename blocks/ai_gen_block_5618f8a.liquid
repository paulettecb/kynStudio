{% doc %}
  @prompt
    infographic on one side, text on the other
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-infographic-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-infographic-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    {% if block.settings.layout == 'text_left' %}
      flex-direction: row-reverse;
    {% else %}
      flex-direction: row;
    {% endif %}
  }

  .ai-infographic-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-infographic-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-infographic-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-infographic-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-infographic-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-infographic-text-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-infographic-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-infographic-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-infographic-text-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-infographic-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-infographic-text-{{ ai_gen_id }} ul,
  .ai-infographic-text-{{ ai_gen_id }} ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .ai-infographic-text-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  @media screen and (max-width: 749px) {
    .ai-infographic-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap | times: 0.7 }}px;
    }

    .ai-infographic-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-infographic-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-infographic-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-infographic-container-{{ ai_gen_id }}">
    <div class="ai-infographic-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.infographic_image %}
        <img
          src="{{ block.settings.infographic_image | image_url: width: 1200 }}"
          alt="{{ block.settings.infographic_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.infographic_image.width }}"
          height="{{ block.settings.infographic_image.height }}"
          class="ai-infographic-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-infographic-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-infographic-empty-state-{{ ai_gen_id }}">
            Next, add an infographic image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-infographic-text-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-infographic-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-infographic-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Infographic with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "infographic_left",
          "label": "Infographic left"
        },
        {
          "value": "text_left",
          "label": "Text left"
        }
      ],
      "default": "infographic_left"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between columns",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Infographic"
    },
    {
      "type": "image_picker",
      "id": "infographic_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Process"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover how we create exceptional products through our carefully designed process. Each step is crafted to ensure quality and innovation.</p>"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Infographic with text"
    }
  ]
}
{% endschema %}
