{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign primary_finish_option_name = 'Primary Finish' %}
{% assign secondary_finish_option_name = 'Secondary Finish' %}
{% assign primary_finish_metafield = product.metafields.shopify['color-pattern'].value %}
{% assign secondary_finish_metafield = product.metafields.custom['secomdary-finish'].value %}

{% style %}
  .ai-variant-picker-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-variant-option-group-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_between_options }}px;
  }

  .ai-variant-option-group-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-variant-option-label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
    margin-bottom: {{ block.settings.label_spacing }}px;
    color: {{ block.settings.label_color }};
    text-transform: {% if block.settings.label_uppercase %}uppercase{% else %}none{% endif %};
  }

  .ai-variant-options-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax({{ block.settings.thumbnail_size }}px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-variant-option-{{ ai_gen_id }} {
    position: relative;
    cursor: pointer;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    transition: all 0.3s ease;
    aspect-ratio: 1;
    background: #ffffff;
    padding: 0;
    appearance: none;
  }

  .ai-variant-option-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.hover_border_color }};
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-variant-option-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.selected_border_color }};
    border-width: {{ block.settings.selected_border_width }}px;
  }

  .ai-variant-option-{{ ai_gen_id }}.is-unavailable {
    opacity: 0.45;
  }

  .ai-variant-option-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-variant-option-name-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: {{ block.settings.overlay_background }};
    color: {{ block.settings.overlay_text_color }};
    padding: 8px;
    font-size: {{ block.settings.name_font_size }}px;
    text-align: center;
    opacity: {% if block.settings.show_name_overlay %}1{% else %}0{% endif %};
    transition: opacity 0.3s ease;
  }

  .ai-variant-option-{{ ai_gen_id }}:hover .ai-variant-option-name-{{ ai_gen_id }},
  .ai-variant-option-{{ ai_gen_id }}.selected .ai-variant-option-name-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-variant-option-checkmark-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    background: {{ block.settings.checkmark_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .ai-variant-option-{{ ai_gen_id }}.selected .ai-variant-option-checkmark-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-variant-option-checkmark-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.checkmark_color }};
  }

  .ai-variant-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
  }

  @media screen and (max-width: 749px) {
    .ai-variant-options-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax({{ block.settings.mobile_thumbnail_size }}px, 1fr));
    }
  }
{% endstyle %}

<script type="application/json" id="ProductData-{{ ai_gen_id }}">
  {{ product | json }}
</script>

<variant-picker-{{ ai_gen_id }} class="ai-variant-picker-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for option in product.options_with_values %}
    <div
      class="ai-variant-option-group-{{ ai_gen_id }}"
      data-option-name="{{ option.name | escape }}"
      data-option-position="{{ option.position }}"
    >
      <label class="ai-variant-option-label-{{ ai_gen_id }}">
        {{ option.name }}:
        <span class="ai-selected-value-{{ ai_gen_id }}" data-selected-label="{{ option.position }}">
          {{ option.selected_value }}
        </span>
      </label>

      <div class="ai-variant-options-grid-{{ ai_gen_id }}">
        {% if option.name == primary_finish_option_name and primary_finish_metafield != blank %}
          {% for entry in primary_finish_metafield %}
            {% assign entry_label = entry.label | default: entry.name | default: entry.title | default: entry.system.handle %}
            {% assign matched_option_value = blank %}
            {% assign entry_label_downcase = entry_label | strip | downcase %}

            {% for option_value in option.values %}
              {% assign option_value_downcase = option_value | strip | downcase %}
              {% if option_value_downcase == entry_label_downcase %}
                {% assign matched_option_value = option_value %}
                {% break %}
              {% endif %}
            {% endfor %}

            {% if matched_option_value != blank %}
              <button
                type="button"
                class="ai-variant-option-{{ ai_gen_id }}{% if matched_option_value == option.selected_value %} selected{% endif %}"
                data-option-position="{{ option.position }}"
                data-option-name="{{ option.name | escape }}"
                data-option-value="{{ matched_option_value | escape }}"
                aria-pressed="{% if matched_option_value == option.selected_value %}true{% else %}false{% endif %}"
              >
                {% if entry.image %}
                  <img
                    src="{{ entry.image | image_url: width: 400 }}"
                    alt="{{ entry_label | escape }}"
                    class="ai-variant-option-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% elsif product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ entry_label | escape }}"
                    class="ai-variant-option-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-variant-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                <div class="ai-variant-option-name-{{ ai_gen_id }}">
                  {{ entry_label }}
                </div>

                {% if block.settings.show_checkmark %}
                  <div class="ai-variant-option-checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"></path>
                    </svg>
                  </div>
                {% endif %}
              </button>
            {% endif %}
          {% endfor %}

        {% elsif option.name == secondary_finish_option_name and secondary_finish_metafield != blank %}
          {% for entry in secondary_finish_metafield %}
            {% assign entry_label = entry.label | default: entry.name | default: entry.title | default: entry.system.handle %}
            {% assign option_values_joined = option.values | join: '||' | downcase %}
            {% assign entry_label_downcase = entry_label | downcase %}

            {% if option_values_joined contains entry_label_downcase %}
              <button
                type="button"
                class="ai-variant-option-{{ ai_gen_id }}{% if entry_label == option.selected_value %} selected{% endif %}"
                data-option-position="{{ option.position }}"
                data-option-name="{{ option.name | escape }}"
                data-option-value="{{ entry_label | escape }}"
                aria-pressed="{% if entry_label == option.selected_value %}true{% else %}false{% endif %}"
              >
                {% if entry.image %}
                  <img
                    src="{{ entry.image | image_url: width: 400 }}"
                    alt="{{ entry_label | escape }}"
                    class="ai-variant-option-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% elsif product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ entry_label | escape }}"
                    class="ai-variant-option-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-variant-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                <div class="ai-variant-option-name-{{ ai_gen_id }}">
                  {{ entry_label }}
                </div>

                {% if block.settings.show_checkmark %}
                  <div class="ai-variant-option-checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"></path>
                    </svg>
                  </div>
                {% endif %}
              </button>
            {% endif %}
          {% endfor %}

        {% else %}
          {% assign option_index = option.position | minus: 1 %}
          {% for value in option.values %}
            {% assign matching_variant = nil %}
            {% for variant in product.variants %}
              {% assign variant_option_value = variant.options[option_index] %}
              {% if variant_option_value == value %}
                {% assign matching_variant = variant %}
                {% break %}
              {% endif %}
            {% endfor %}

            <button
              type="button"
              class="ai-variant-option-{{ ai_gen_id }}{% if value == option.selected_value %} selected{% endif %}"
              data-option-position="{{ option.position }}"
              data-option-name="{{ option.name | escape }}"
              data-option-value="{{ value | escape }}"
              aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
            >
              {% if matching_variant and matching_variant.featured_image %}
                <img
                  src="{{ matching_variant.featured_image | image_url: width: 400 }}"
                  alt="{{ value | escape }}"
                  class="ai-variant-option-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% elsif product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  alt="{{ value | escape }}"
                  class="ai-variant-option-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-variant-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              <div class="ai-variant-option-name-{{ ai_gen_id }}">
                {{ value }}
              </div>

              {% if block.settings.show_checkmark %}
                <div class="ai-variant-option-checkmark-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"></path>
                  </svg>
                </div>
              {% endif %}
            </button>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  {% endfor %}
</variant-picker-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantPicker extends HTMLElement {
      constructor() {
        super();
        this.product = null;
        this.selectedOptions = [];
      }

      connectedCallback() {
        var productDataEl = document.getElementById('ProductData-{{ ai_gen_id }}');
        if (!productDataEl) return;

        this.product = JSON.parse(productDataEl.textContent);

        this.initializeSelectedOptions();
        this.attachEventListeners();
        this.updateUI();
        this.syncNativeVariantInput();
        this.updateMainImage();
      }

      initializeSelectedOptions() {
        var urlParams = new URLSearchParams(window.location.search);
        var variantParam = urlParams.get('variant');

        if (variantParam) {
          var variantFromUrl = this.product.variants.find(function(v) {
            return String(v.id) === String(variantParam);
          });

          if (variantFromUrl) {
            this.selectedOptions = variantFromUrl.options.slice();
            return;
          }
        }

        var selectedVariant =
          this.product.variants.find(function(variant) {
            return variant.id === (this.product.selected_or_first_available_variant && this.product.selected_or_first_available_variant.id);
          }.bind(this)) ||
          this.product.variants.find(function(variant) {
            return variant.available;
          }) ||
          this.product.variants[0];

        this.selectedOptions = selectedVariant ? selectedVariant.options.slice() : [];
      }

      attachEventListeners() {
        var options = this.querySelectorAll('.ai-variant-option-{{ ai_gen_id }}');

        options.forEach(function(optionEl) {
          optionEl.addEventListener('click', function() {
            var position = parseInt(optionEl.dataset.optionPosition, 10);
            var value = optionEl.dataset.optionValue;

            this.selectedOptions[position - 1] = value;

            var variant = this.getCurrentVariant();
            if (!variant) {
              variant = this.getClosestAvailableVariant(position - 1, value);
            }

            if (variant) {
              this.selectedOptions = variant.options.slice();
            }

            this.updateUI();
            this.updateURL();
            this.syncNativeVariantInput();
            this.updateMainImage();
            this.dispatchVariantChange();
          }.bind(this));
        }.bind(this));
      }

      getCurrentVariant() {
        return this.product.variants.find(function(variant) {
          return variant.options.every(function(optionValue, index) {
            return optionValue === this.selectedOptions[index];
          }.bind(this));
        }.bind(this));
      }

      getClosestAvailableVariant(changedIndex, changedValue) {
        return this.product.variants.find(function(variant) {
          return variant.available && variant.options[changedIndex] === changedValue;
        });
      }

      updateUI() {
        var matchingVariant = this.getCurrentVariant();

        this.querySelectorAll('.ai-variant-option-{{ ai_gen_id }}').forEach(function(optionEl) {
          var position = parseInt(optionEl.dataset.optionPosition, 10);
          var value = optionEl.dataset.optionValue;
          var isSelected = this.selectedOptions[position - 1] === value;

          optionEl.classList.toggle('selected', isSelected);
          optionEl.setAttribute('aria-pressed', isSelected ? 'true' : 'false');

          var testOptions = this.selectedOptions.slice();
          testOptions[position - 1] = value;

          var availableCombination = this.product.variants.some(function(variant) {
            if (!variant.available) return false;

            return variant.options.every(function(variantOption, index) {
              return testOptions[index] === variantOption;
            });
          });

          optionEl.classList.toggle('is-unavailable', !availableCombination);
        }.bind(this));

        this.querySelectorAll('.ai-selected-value-{{ ai_gen_id }}').forEach(function(span, index) {
          span.textContent = this.selectedOptions[index] || '';
        }.bind(this));

        if (matchingVariant) {
          this.dataset.currentVariantId = matchingVariant.id;
        }
      }

      updateURL() {
        var variant = this.getCurrentVariant();
        if (!variant) return;

        var url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url);
      }

      syncNativeVariantInput() {
        var variant = this.getCurrentVariant();
        if (!variant) return;

        var productForm =
          this.closest('section, product-info, main, .shopify-section') &&
          this.closest('section, product-info, main, .shopify-section').querySelector('form[action*="/cart/add"]');

        if (!productForm) {
          productForm = document.querySelector('form[action*="/cart/add"]');
        }

        if (!productForm) return;

        var variantInput = productForm.querySelector('input[name="id"]');
        if (!variantInput) return;

        variantInput.value = variant.id;
        variantInput.dispatchEvent(new Event('change', { bubbles: true }));
      }

      updateMainImage() {
        var variant = this.getCurrentVariant();
        if (!variant || !variant.featured_media) return;

        var mediaId = String(variant.featured_media.id);
        var mediaItem =
          document.querySelector('[data-media-id="' + mediaId + '"]') ||
          document.querySelector('[data-media-id$="' + mediaId + '"]');

        if (mediaItem) {
          mediaItem.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      }

      dispatchVariantChange() {
        var variant = this.getCurrentVariant();
        if (!variant) return;

        this.dispatchEvent(new CustomEvent('variant-change', {
          detail: { variant: variant },
          bubbles: true,
          composed: true
        }));

        document.dispatchEvent(new CustomEvent('variant:changed', {
          detail: { variant: variant }
        }));
      }
    }

    if (!customElements.get('variant-picker-{{ ai_gen_id }}')) {
      customElements.define('variant-picker-{{ ai_gen_id }}', VariantPicker);
    }
  })();
</script>

{% schema %}
{
  "name": "Variant image picker",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "thumbnail_size",
      "label": "Desktop thumbnail size",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_thumbnail_size",
      "label": "Mobile thumbnail size",
      "min": 50,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Space between thumbnails",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "spacing_between_options",
      "label": "Space between option groups",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Option labels"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "checkbox",
      "id": "label_uppercase",
      "label": "Uppercase labels",
      "default": false
    },
    {
      "type": "range",
      "id": "label_spacing",
      "label": "Space below label",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Thumbnail borders"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "hover_border_color",
      "label": "Hover border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Selected state"
    },
    {
      "type": "range",
      "id": "selected_border_width",
      "label": "Selected border width",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "selected_border_color",
      "label": "Selected border color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "show_checkmark",
      "label": "Show checkmark on selected",
      "default": true
    },
    {
      "type": "color",
      "id": "checkmark_background",
      "label": "Checkmark background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "checkmark_color",
      "label": "Checkmark color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Variant name overlay"
    },
    {
      "type": "checkbox",
      "id": "show_name_overlay",
      "label": "Show name by default",
      "default": false
    },
    {
      "type": "range",
      "id": "name_font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "overlay_background",
      "label": "Overlay background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Overlay text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Variant image picker"
    }
  ]
}
{% endschema %}

{% if request.design_mode %}
  <div id="variant-debug-panel" style="margin-top:20px;padding:12px;background:#f4f4f4;border:1px solid #ccc;font-family:monospace;font-size:12px;border-radius:6px;">
    <strong>🛠 Debug Panel</strong>
    <p><b>Product options:</b>
      {% for option in product.options_with_values %}
        <br>{{ option.name }}: {{ option.values | join: ', ' }}
      {% endfor %}
    </p>
    <p><b>Selected variant (Liquid):</b> {{ product.selected_value.id | default: 'none' }}</p>
    <p><b>Selected options:</b>
      {% for option in product.selected_or_first_available_variant.options %}
        {{ option }}{% unless forloop.last %}, {% endunless %}
      {% endfor %}
    </p>
    <p><b>Cart form variant ID (live):</b> <span id="debug-cart-id">checking...</span></p>
  </div>
  <script>
    (function() {
      function updateDebug() {
        var input = document.querySelector('form[action="/cart/add"] [name="id"]');
        var el = document.getElementById('debug-cart-id');
        if (el) el.textContent = input ? input.value : 'not found';
      }
      updateDebug();
      document.addEventListener('change', updateDebug);
      var obs = new MutationObserver(updateDebug);
      var form = document.querySelector('form[action="/cart/add"]');
      if (form) obs.observe(form, { subtree: true, attributes: true, attributeFilter: ['value'] });
    })();
  </script>
{% endif %}
