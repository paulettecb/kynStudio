{% doc %}
  @prompt
    I need a table, I'll give you the code, but I need it to be fully customizable through the customization section
    
    <div style="margin: 60px 0;">
      <h4 style="text-transform: uppercase; font-family: 'Nanum Pen Script', sans-serif; font-size: 10px; letter-spacing: 2px; color: #B28D15; margin-bottom: 20px; text-align: center;">Análisis Comparativo de Materiales</h4>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; color: #fff; font-size: 11px; text-transform: uppercase;">
          <thead>
            <tr style="border-bottom: 2px solid #333;">
              <th style="padding: 15px 5px; text-align: left; color: #888;">Característica</th>
              <th style="padding: 15px 5px; text-align: center; color: #B28D15;">KYN Biothane®</th>
              <th style="padding: 15px 5px; text-align: center; color: #444;">Nylon</th>
              <th style="padding: 15px 5px; text-align: center; color: #444;">Cuero</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid #222;">
              <td style="padding: 12px 5px; color: #888;">No absorbe agua</td>
              <td style="padding: 12px 5px; text-align: center;">✓</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
            </tr>
            <tr style="border-bottom: 1px solid #222;">
              <td style="padding: 12px 5px; color: #888;">Libre de olores</td>
              <td style="padding: 12px 5px; text-align: center;">✓</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
            </tr>
            <tr style="border-bottom: 1px solid #222;">
              <td style="padding: 12px 5px; color: #888;">Limpieza instantánea</td>
              <td style="padding: 12px 5px; text-align: center;">✓</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
            </tr>
            <tr style="border-bottom: 1px solid #222;">
              <td style="padding: 12px 5px; color: #888;">Resistencia UV</td>
              <td style="padding: 12px 5px; text-align: center;">✓</td>
              <td style="padding: 12px 5px; text-align: center; color: #444;">✕</td>
              <td style="padding: 12px 5px; text-align: center;">✓</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>, Instead of adding static rows and columns that go on and off, could you add an option to add column or row? I think it would be better user experience inside the customizable board
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  h4 {
    font-family: 'Nanum Pen Script', sans-serif;
  }
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.margin_top }}px auto {{ block.settings.margin_bottom }}px;
    font-family: {{ block.settings.table_font.family }}, {{ block.settings.table_font.fallback_families }};
  }

  .ai-comparison-table__heading-{{ ai_gen_id }} {
    text-transform: uppercase;
    font-size: {{ block.settings.heading_size }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    color: {{ block.settings.heading_color }};
    margin-bottom: {{ block.settings.heading_margin_bottom }}px;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead tr {
    border-bottom: {{ block.settings.header_border_width }}px solid {{ block.settings.header_border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th {
    padding: {{ block.settings.header_padding_vertical }}px {{ block.settings.header_padding_horizontal }}px;
    text-align: left;
    font-weight: {{ block.settings.header_font_weight }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th:first-child {
    color: {{ block.settings.feature_label_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th:nth-child(2) {
    text-align: {{ block.settings.column_alignment }};
    color: {{ block.settings.highlight_column_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} thead th:not(:first-child):not(:nth-child(2)) {
    text-align: {{ block.settings.column_alignment }};
    color: {{ block.settings.other_columns_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody tr {
    border-bottom: {{ block.settings.row_border_width }}px solid {{ block.settings.row_border_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody td {
    padding: {{ block.settings.cell_padding_vertical }}px {{ block.settings.cell_padding_horizontal }}px;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody td:first-child {
    color: {{ block.settings.feature_label_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody td:nth-child(2) {
    text-align: {{ block.settings.column_alignment }};
    color: {{ block.settings.highlight_column_color }};
  }

  .ai-comparison-table__table-{{ ai_gen_id }} tbody td:not(:first-child):not(:nth-child(2)) {
    text-align: {{ block.settings.column_alignment }};
    color: {{ block.settings.other_columns_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-comparison-table__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-comparison-table__table-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-comparison-table__table-{{ ai_gen_id }} thead th,
    .ai-comparison-table__table-{{ ai_gen_id }} tbody td {
      padding: {{ block.settings.cell_padding_vertical | times: 0.8 }}px {{ block.settings.cell_padding_horizontal | times: 0.7 }}px;
    }
  }
{% endstyle %}

