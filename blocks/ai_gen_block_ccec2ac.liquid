{% doc %}
  @prompt
    Create a mobile-optimized version of an existing comparison table block. The table compares materials for pet/dog accessories. Here are all the details to replicate:
    
    HEADING: "Analisis Comparativo de Materiales" — 24px, gold color #9b7a0f, centered, letter-spacing 3px, font: Nanum Pen Script (nanum_pen_script_n4)
    
    COLUMNS: Características (feature labels) | KYN Biothane® (highlighted) | Nylon | Cuero
    
    ROWS (4 rows):
    - No absorbe agua: ✓ | ✕ | ✕
    - Libre de olores: ✓ | ✕ | ✕
    - Limpieza instantánea: ✓ | ✕ | ✕
    - Resistencia UV: ✓ | ✓ | ✓
    
    COLORS: Text #ffffff, feature label color #273448, highlight column (KYN Biothane®) #9b7a0f gold, other columns #273448 dark blue-grey. Row borders 1px #273448.
    
    BUTTON below table: Label "Conoce más sobre el latón", links to shopify://pages/why-solid-brass, primary style, full width.
    
    MOBILE DESIGN REQUIREMENTS:
    - On mobile, instead of a horizontal table, show each material (KYN Biothane®, Nylon, Cuero) as a stacked card
    - Each card shows the material name as a header, then lists each feature with a ✓ or ✕
    - KYN Biothane® card should be visually highlighted with the gold color #9b7a0f
    - On desktop, keep the original horizontal table layout
    - Use CSS media queries to switch between layouts
    - All fonts should use the theme's font variables: heading font nanum_pen_script_n4, body font red_hat_text_n4
    - Text uppercase, clean and modern look matching the existing brand colors, In the layout customization you need to add a mobile section as well as the desktop one, but other that that, is amazing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-material-comparison-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-material-comparison__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: center;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    margin: 0 0 32px;
    text-transform: uppercase;
  }

  .ai-material-comparison__table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
  }

  .ai-material-comparison__table-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
  }

  .ai-material-comparison__table-{{ ai_gen_id }} th,
  .ai-material-comparison__table-{{ ai_gen_id }} td {
    padding: 16px;
    text-align: center;
    border-bottom: 1px solid {{ block.settings.border_color }};
    text-transform: uppercase;
  }

  .ai-material-comparison__table-{{ ai_gen_id }} th {
    font-weight: 600;
    font-size: 16px;
  }

  .ai-material-comparison__table-{{ ai_gen_id }} td {
    font-size: 14px;
  }

  .ai-material-comparison__table-{{ ai_gen_id }} th:first-child,
  .ai-material-comparison__table-{{ ai_gen_id }} td:first-child {
    text-align: left;
    color: {{ block.settings.feature_label_color }};
  }

  .ai-material-comparison__table-{{ ai_gen_id }} th.ai-material-comparison__highlight-{{ ai_gen_id }},
  .ai-material-comparison__table-{{ ai_gen_id }} td.ai-material-comparison__highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_bg_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-material-comparison__table-{{ ai_gen_id }} th:not(.ai-material-comparison__highlight-{{ ai_gen_id }}):not(:first-child),
  .ai-material-comparison__table-{{ ai_gen_id }} td:not(.ai-material-comparison__highlight-{{ ai_gen_id }}):not(:first-child) {
    background-color: {{ block.settings.column_bg_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-material-comparison__check-{{ ai_gen_id }} {
    color: {{ block.settings.check_color }};
    font-size: 20px;
    font-weight: bold;
  }

  .ai-material-comparison__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
    font-size: 20px;
    font-weight: bold;
  }

  .ai-material-comparison__mobile-cards-{{ ai_gen_id }} {
    display: none;
  }

  .ai-material-comparison__button-wrapper-{{ ai_gen_id }} {
    margin-top: 32px;
  }

  .ai-material-comparison__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-material-comparison__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-material-comparison-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-material-comparison__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-material-comparison__table-wrapper-{{ ai_gen_id }} {
      display: none;
    }

    .ai-material-comparison__mobile-cards-{{ ai_gen_id }} {
      display: block;
    }

    .ai-material-comparison__card-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_card_spacing }}px;
      border: 1px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.mobile_card_border_radius }}px;
      overflow: hidden;
    }

    .ai-material-comparison__card-header-{{ ai_gen_id }} {
      padding: 16px;
      text-align: center;
      font-weight: 600;
      font-size: {{ block.settings.mobile_card_header_size }}px;
      text-transform: uppercase;
      color: {{ block.settings.text_color }};
    }

    .ai-material-comparison__card-header-{{ ai_gen_id }}.ai-material-comparison__highlight-{{ ai_gen_id }} {
      background-color: {{ block.settings.highlight_bg_color }};
    }

    .ai-material-comparison__card-header-{{ ai_gen_id }}:not(.ai-material-comparison__highlight-{{ ai_gen_id }}) {
      background-color: {{ block.settings.column_bg_color }};
    }

    .ai-material-comparison__card-body-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-material-comparison__card-row-{{ ai_gen_id }} {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid {{ block.settings.border_color }};
    }

    .ai-material-comparison__card-row-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }

    .ai-material-comparison__card-label-{{ ai_gen_id }} {
      color: {{ block.settings.feature_label_color }};
      font-size: {{ block.settings.mobile_card_label_size }}px;
      text-transform: uppercase;
    }

    .ai-material-comparison__card-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_card_value_size }}px;
    }
  }
{% endstyle %}

