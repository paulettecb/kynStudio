{% # theme-check-disable %}
{%- liquid
  assign custom_font_woff2 = blank

  case settings.custom_font_family
    when 'friendship'
      assign custom_font_woff2 = 'Friendship-Medium.woff2'
    when 'farmhouse'
      assign custom_font_woff2 = 'Farmhouse.woff2'
  endcase
-%}
{%- if custom_font_woff2 != blank -%}
  <link
    rel="preload"
    as="font"
    href="{{ custom_font_woff2 | asset_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endif -%}
{%- unless settings.type_body_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_body_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_subheading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_subheading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_heading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_heading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_accent_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_accent_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{% # theme-check-enable %}
