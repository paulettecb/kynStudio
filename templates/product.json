            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "text_BGLpNi": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>Our decision to import hardware from the United States and Europe came from one principle: refusing low-grade zamak or chrome-plated zinc commonly found in the local market.</p><p></p><ul><li><strong>Cast brass:</strong> The O-rings and D-rings in your pieces are cast, which removes welded joints and increases structural strength.</li></ul><p></p><ul><li><strong>Low Lead (LL):</strong> We use solid brass, a non-ferrous alloy naturally resistant to corrosion and rust, even near the sea.<br/>It complies with international safety standards (such as California Proposition 65), meaning lead content is minimal or non-existent.<br/><br/>Because this hardware stays in constant contact with both your hands and your dog’s neck, using <strong>Low Lead</strong> materials helps ensure a safe, non-toxic product.</li></ul><p></p><ul><li><strong>Galvanic finish:</strong> Each piece includes an <strong>18k gold</strong> plating that delivers elevated aesthetics without sacrificing durability for real-world use.</li></ul><p></p>",
            "width": "100%",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "rte",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
