        "text_piDNey": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<p><strong>Metalurgia de Precisión: </strong></p>",
            "width": "fit-content",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-body--family)",
