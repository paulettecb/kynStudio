        },
        "text_t9R3tp": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>It is not leather, and it is not plastic—it is engineering applied to everyday walks. BioThane® is a patented material built from a polyester-webbing core coated in PVC, offering tensile strength above <strong>450 kg</strong>.</p><p></p><ul><li><strong>Hydrophobic and antimicrobial:</strong> Unlike nylon, it does not absorb water or generate odors, preserving structural integrity in demanding urban conditions.</li></ul><p></p><ul><li><strong>Technical flexibility:</strong> It retains softness and grip even in sub-zero temperatures, without cracking or losing color over time.</li></ul><p></p>",
            "width": "100%",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "rte",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "color": "var(--color-foreground)",
            "background": false,
            "background_color": "#00000026",
            "corner_radius": 0,
            "padding-block-start": 14,
            "padding-block-end": 0,
            "padding-inline-start": 31,
            "padding-inline-end": 33
          },
          "blocks": {}
        },
        "divider_REcHwR": {
          "type": "_divider",
          "name": "t:names.divider",
          "settings": {
            "thickness": 1,
            "corner_radius": "square",
