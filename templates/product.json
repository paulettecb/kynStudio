        "text_L3w4jM": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<h2>High-Performance Polymer</h2>",
            "width": "fit-content",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "h3",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
