        },
        "text_XUNDGG": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>At <strong>KYN Studio</strong>, we reject traditional press rivets that weaken under constant impact.</p><ul><li><strong>Active safety:</strong> We use security screws (Chicago Screws) that create a true mechanical bond between BioThane® layers.</li></ul><p></p><ul><li><strong>Industrial maintenance:</strong> This assembly method allows inspection and, when needed, adjustment—keeping the connection point the strongest area of the leash, not the weakest.</li></ul><p></p>",
            "width": "100%",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "rte",
