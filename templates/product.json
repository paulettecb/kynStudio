        "text_XePytq": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p><strong>Latón Sólido (LL) + 18k Gold</strong></p>",
            "width": "fit-content",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "h3",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
