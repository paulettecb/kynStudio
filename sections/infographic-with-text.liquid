<div
  class="section section--full-width infographic-with-text spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --infographic-max-width: {{ section.settings.max_width }}px;
    --infographic-background-color: 'radial-gradient(circle at top right, #e2e8f0 0%, #cbd5e1 100%)';
  "
>
  <div class="section-background" style="background: radial-gradient(circle at top right, #e2e8f0 0%, #cbd5e1 100%);"></div>

  <div class="infographic-with-text__inner{% if section.settings.image_position == 'left' %} infographic-with-text__inner--image-left{% endif %}">
    <div class="infographic-with-text__content">
      {% if section.settings.subtitle != blank %}
        <p class="infographic-with-text__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="infographic-with-text__title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.rich_text != blank %}
        <div class="infographic-with-text__rte rte">{{ section.settings.rich_text }}</div>
      {% endif %}
    </div>

    <div class="infographic-with-text__media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 2400
          | image_tag:
            class: 'infographic-with-text__image',
            widths: '600, 900, 1200, 1600, 2000, 2400',
            loading: 'lazy',
            sizes: '(min-width: 990px) 56vw, 100vw'
        }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg infographic-with-text__image infographic-with-text__image--placeholder' }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Infographic with text",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Materials & Craft"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Designed for clarity, built for everyday use"
    },
    {
      "type": "richtext",
      "id": "rich_text",
      "label": "Text",
      "default": "<p>Pair concise copy with a strong visual story. This section is ideal for premium editorial moments where product performance and aesthetics meet.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Infographic image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 1100,
      "max": 2400,
      "step": 20,
      "unit": "px",
      "default": 1800
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f6f3ee"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Left spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Right spacing",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Infographic with text"
    }
  ]
}
{% endschema %}
