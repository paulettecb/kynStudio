<div class="atelier-home-banner" role="note" aria-label="Atelier shipping notice">
  <div class="atelier-home-banner__marquee" aria-live="polite">
    <div class="atelier-home-banner__track">
      <p class="atelier-home-banner__text">
        {{ 'custom_marketing.atelier_notice' | t }}
      </p>
      <p class="atelier-home-banner__text" aria-hidden="true">
        {{ 'custom_marketing.atelier_notice' | t }}
      </p>
    </div>
  </div>
</div>

{% stylesheet %}
  .atelier-home-banner {
    background: #101010;
    color: #ffffff;
    padding: clamp(1rem, 2.2vw, 1.6rem) 1.25rem;
    overflow: hidden;
  }

  .atelier-home-banner__marquee {
    width: 100%;
    overflow: hidden;
  }

  .atelier-home-banner__track {
    display: flex;
    width: max-content;
    min-width: 100%;
    animation: atelier-notice-marquee 18s linear infinite;
  }

  .atelier-home-banner__text {
    font-family: var(--font-body--family);
    font-size: clamp(0.75rem, 1.2vw, 0.9rem);
    letter-spacing: 0.12em;
    line-height: 1.6;
    margin: 0 auto;
    max-width: 1200px;
    text-align: center;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
    flex-shrink: 0;
    padding-inline: min(6vw, 4rem);
  }

  @media screen and (max-width: 749px) {
    .atelier-home-banner {
      padding: 0.95rem 1rem;
    }

    .atelier-home-banner__text {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      line-height: 1.45;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .atelier-home-banner__track {
      animation: none;
    }
  }

  @keyframes atelier-notice-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Atelier notice banner",
  "tag": "section",
  "class": "section"
}
{% endschema %}
