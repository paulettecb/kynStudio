{% doc %}
  @prompt
    Update the existing AI-generated block (ai_gen_block_21d728f_wa7TwR) in the product details section to display the image from the selected color variant's metaobject. The product has a metafield shopify.color-pattern of type list.metaobject_reference. Each metaobject of type shopify--color-pattern has an image field of type file_reference. The block should dynamically show the image from the currently selected color's metaobject entry, updating when the customer selects a different color variant.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign color_option_name = 'Color'
  
  for option in product.options_with_values
    assign option_name_downcase = option.name | downcase
    if option_name_downcase contains 'color' or option_name_downcase contains 'colour'
      assign color_option_name = option.name
      break
    endif
  endfor
  
  assign selected_color_value = ''
  for option in selected_variant.options
    assign option_index = forloop.index0
    if product.options_with_values[option_index].name == color_option_name
      assign selected_color_value = option
      break
    endif
  endfor
  
  assign color_pattern_metafield = product.metafields.shopify.color-pattern
  assign selected_color_image = null
  
  if color_pattern_metafield != blank
    for color_metaobject in color_pattern_metafield.value
      assign metaobject_name = color_metaobject.name | downcase | strip
      assign selected_color_downcase = selected_color_value | downcase | strip
      
      if metaobject_name == selected_color_downcase
        assign selected_color_image = color_metaobject.image
        break
      endif
    endfor
  endif
%}

{% style %}
  .ai-color-variant-image-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-color-variant-image__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-color-variant-image__img-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-color-variant-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_bg_color }};
    position: relative;
  }

  .ai-color-variant-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-color-variant-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    text-align: center;
    pointer-events: none;
    max-width: 90%;
  }

  .ai-color-variant-image__caption-{{ ai_gen_id }} {
    margin-top: {{ block.settings.caption_spacing }}px;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-color-variant-image-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<color-variant-image-{{ ai_gen_id }}
  class="ai-color-variant-image-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-color-variant-image__wrapper-{{ ai_gen_id }}">
    {% if selected_color_image != blank %}
      <img
        src="{{ selected_color_image | image_url: width: 2000 }}"
        alt="{{ selected_color_image.alt | default: selected_color_value | escape }}"
        loading="lazy"
        width="{{ selected_color_image.width }}"
        height="{{ selected_color_image.height }}"
        class="ai-color-variant-image__img-{{ ai_gen_id }}"
        data-color-image
      >
    {% else %}
      <div class="ai-color-variant-image__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-color-variant-image__empty-state-{{ ai_gen_id }}">
          {% if color_pattern_metafield == blank %}
            Add color pattern metafield to product
          {% else %}
            No image found for selected color
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_caption and selected_color_value != blank %}
    <div class="ai-color-variant-image__caption-{{ ai_gen_id }}">
      {{ block.settings.caption_prefix }}{{ selected_color_value }}
    </div>
  {% endif %}
</color-variant-image-{{ ai_gen_id }}>

<script>
  (function() {
    class ColorVariantImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productId = this.dataset.productId;
      }

      connectedCallback() {
        this.setupVariantListener();
      }

      setupVariantListener() {
        const productForm = document.querySelector(`product-form[data-product-id="${this.productId}"]`) || 
                           document.querySelector('product-form') ||
                           document.querySelector('form[action*="/cart/add"]');

        if (!productForm) {
          return;
        }

        const variantInputs = productForm.querySelectorAll('input[name="id"], select[name="id"]');
        
        variantInputs.forEach(input => {
          input.addEventListener('change', () => {
            this.handleVariantChange();
          });
        });

        const variantSelects = productForm.querySelectorAll('variant-selects, variant-radios');
        variantSelects.forEach(selector => {
          selector.addEventListener('change', () => {
            this.handleVariantChange();
          });
        });

        document.addEventListener('variant:change', (event) => {
          if (event.detail && event.detail.variant) {
            this.handleVariantChange();
          }
        });
      }

      handleVariantChange() {
        setTimeout(() => {
          window.location.reload();
        }, 100);
      }
    }

    customElements.define('color-variant-image-{{ ai_gen_id }}', ColorVariantImage{{ ai_gen_id }});
  })();
</script>

