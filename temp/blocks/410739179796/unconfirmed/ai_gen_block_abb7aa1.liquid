{% doc %}
  @prompt
    Create a full-width scrolling marquee announcement banner that displays text continuously moving from right to left across the full width of the page. The banner should have customizable background color, text color, font size, and scrolling speed. It should seamlessly loop the text and look clean and modern, matching the store's header area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-marquee-banner__track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-marquee-banner__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-right: {{ block.settings.text_spacing }}px;
  }

  .ai-marquee-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0;
  }

  .ai-marquee-banner__separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.separator_spacing }}px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-marquee-banner-{{ ai_gen_id }}:hover .ai-marquee-banner__track-{{ ai_gen_id }} {
    animation-play-state: {{ block.settings.pause_on_hover | default: false | if: 'paused', 'running' }};
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-banner__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.8);
    }
  }
{% endstyle %}

<marquee-banner-{{ ai_gen_id }} class="ai-marquee-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-banner__track-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      <div class="ai-marquee-banner__content-{{ ai_gen_id }}">
        {% if block.settings.announcement_text != blank %}
          <p class="ai-marquee-banner__text-{{ ai_gen_id }}">{{ block.settings.announcement_text }}</p>
        {% else %}
          <p class="ai-marquee-banner__text-{{ ai_gen_id }}">Add your announcement text here</p>
        {% endif %}
        
        {% if block.settings.show_separator %}
          <span class="ai-marquee-banner__separator-{{ ai_gen_id }}"></span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</marquee-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-banner__track-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-marquee-banner__content-{{ ai_gen_id }}');
        
        if (this.track && this.content) {
          this.duplicateContent();
        }
      }

      duplicateContent() {
        const contentWidth = this.content.offsetWidth;
        const viewportWidth = this.offsetWidth;
        const repetitionsNeeded = Math.ceil(viewportWidth / contentWidth) + 2;
        
        const currentRepetitions = this.track.querySelectorAll('.ai-marquee-banner__content-{{ ai_gen_id }}').length;
        
        for (let i = currentRepetitions; i < repetitionsNeeded * 2; i++) {
          const clone = this.content.cloneNode(true);
          this.track.appendChild(clone);
        }
      }
    }

    customElements.define('marquee-banner-{{ ai_gen_id }}', MarqueeBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling marquee banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $50 • New arrivals weekly • Shop now and save 20%"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Separator size",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "separator_spacing",
      "label": "Separator spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Scrolling marquee banner"
    }
  ]
}
{% endschema %}
